      onmouseover="this.style.transform='scale(1.08)';this.style.boxShadow='0 6px 20px rgba(0,70,77,0.5)'"
      onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 4px 16px rgba(0,70,77,0.4)'">
      <span id="support-icon" class="material-symbols-outlined" style="color:white;font-size:22px;">smart_toy</span>
    </button>

    <!-- Badge số tin nhắn chưa đọc -->
    <span id="support-badge"
      style="display:none;position:absolute;top:-2px;right:-2px;background:#EC6D33;color:white;font-size:10px;font-weight:700;min-width:18px;height:18px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 4px;">!</span>
