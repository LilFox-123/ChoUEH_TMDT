      style="display:none;position:absolute;bottom:60px;right:0;width:320px;background:#ffffff;border-radius:16px;box-shadow:0 8px 32px rgba(0,0,0,0.18);overflow:hidden;transform:translateY(8px);opacity:0;transition:transform 0.2s ease,opacity 0.2s ease;">
      <div style="background:#00464d;padding:12px 16px;">
        <p style="color:white;font-size:13px;font-weight:700;margin:0;">🌱 Zeen AI - Trợ lý Chợ UEH</p>
        <p style="color:rgba(255,255,255,0.7);font-size:11px;margin:4px 0 0;">Hỏi mình bất cứ điều gì về Chợ UEH!</p>
      </div>

      <!-- Zeen AI Chat Area -->
      <div id="zeen-chat-area" style="display:flex;flex-direction:column;height:320px;">
