  <script>
    (function () {
      var modal = document.getElementById('support-modal');
      var icon = document.getElementById('support-icon');
      var isOpen = false;

      window.toggleSupportModal = function () {
        isOpen = !isOpen;
        if (isOpen) {
          modal.style.display = 'block';
          setTimeout(function () {
            modal.style.transform = 'translateY(0)';
            modal.style.opacity = '1';
          }, 10);
          icon.textContent = 'close';
          zeenInit();
        } else {
          modal.style.transform = 'translateY(8px)';
          modal.style.opacity = '0';
          icon.textContent = 'smart_toy';
          setTimeout(function () { modal.style.display = 'none'; }, 200);
        }
      };

      // Click outside to close
      document.addEventListener('click', function (e) {
        var fab = document.getElementById('support-fab');
        if (isOpen && fab && !fab.contains(e.target)) {
          window.toggleSupportModal();
        }
      });

      // Tự động điền link nhắn tin admin nếu đã đăng nhập
      fetch('/api/users/admin-id').then(function (r) { return r.json(); }).then(function (d) {
        if (d && d.adminId) {
          var link = document.getElementById('support-message-link');
          if (link) link.href = '/messages?userId=' + d.adminId;
        }
      }).catch(function () { });
    })();

    // Zeen AI Chat Functions
    var zeenHistory = [];
    var zeenHasInteracted = false;
    var zeenInitialized = false;

    function escapeHTML(str) {
      return String(str || '').replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function zeenInit() {
      if (zeenInitialized) return;
      zeenInitialized = true;
      zeenAddBubble('bot', 'Xin chào! Mình là Zeen AI 🌱 Mình có thể giúp bạn tìm sản phẩm, hướng dẫn sử dụng Chợ UEH, hoặc giải đáp thắc mắc. Bạn cần gì nào?');
    }

    function zeenAddBubble(role, text, products) {
      var container = document.getElementById('zeen-messages');
      var bubble = document.createElement('div');
      var isBot = role === 'bot';
      bubble.style.cssText = isBot
        ? 'background:#f0f9fa;border-radius:12px 12px 12px 0;padding:8px 12px;font-size:12px;color:#151d1e;max-width:85%;line-height:1.5;'
        : 'background:#00464d;border-radius:12px 12px 0 12px;padding:8px 12px;font-size:12px;color:white;max-width:85%;align-self:flex-end;line-height:1.5;';
      bubble.textContent = text;
      container.appendChild(bubble);

      if (products && products.length > 0) {
        var cards = document.createElement('div');
        cards.style.cssText = 'display:flex;flex-direction:column;gap:6px;margin-top:4px;';
        products.forEach(function (p) {
          var card = document.createElement('a');
          card.href = '/product/' + p._id;
          card.target = '_blank';
          card.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 8px;background:white;border:1px solid #e1eaeb;border-radius:8px;text-decoration:none;';
          var img = document.createElement('img');
          img.src = (p.images && p.images[0]) || 'https://placehold.co/32x32/e1eaeb/6f797a?text=?';
          img.style.cssText = 'width:32px;height:32px;object-fit:cover;border-radius:4px;flex-shrink:0;';
          var info = document.createElement('div');
          info.style.cssText = 'flex:1;min-width:0;';
          info.innerHTML = '<p style="font-size:11px;font-weight:600;color:#151d1e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + escapeHTML(p.title) + '</p><p style="font-size:11px;color:#EC6D33;font-weight:700;">' + (p.price ? p.price.toLocaleString('vi-VN') + 'đ' : 'Thương lượng') + '</p>';
          card.appendChild(img);
          card.appendChild(info);
          cards.appendChild(card);
        });
        container.appendChild(cards);
      }

      container.scrollTop = container.scrollHeight;
    }

    function zeenSuggest(text) {
      document.getElementById('zeen-input').value = text;
      zeenSendMessage();
    }

    async function zeenSendMessage() {
      var input = document.getElementById('zeen-input');
      var msg = input.value.trim();
      if (!msg) return;

      if (!zeenHasInteracted) {
        zeenHasInteracted = true;
        var sug = document.getElementById('zeen-suggestions');
        if (sug) sug.style.display = 'none';
      }

      input.value = '';
      zeenAddBubble('user', msg);

      document.getElementById('zeen-typing').style.display = 'block';
      document.getElementById('zeen-send').disabled = true;

      try {
        var res = await fetch('/api/ai/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg, history: zeenHistory })
        });
        var data = await res.json();

        document.getElementById('zeen-typing').style.display = 'none';
        document.getElementById('zeen-send').disabled = false;

        if (data.success) {
          zeenHistory.push({ role: 'user', content: msg });
          zeenHistory.push({ role: 'assistant', content: data.reply });
          if (zeenHistory.length > 20) zeenHistory = zeenHistory.slice(-20);
          zeenAddBubble('bot', data.reply, data.products);
        } else {
          zeenAddBubble('bot', data.message || 'Có lỗi xảy ra, bạn thử lại nhé 😅');
        }
      } catch (e) {
        document.getElementById('zeen-typing').style.display = 'none';
        document.getElementById('zeen-send').disabled = false;
        zeenAddBubble('bot', 'Zeen AI đang bận, vui lòng thử lại sau nhé! 🙏');
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      var inp = document.getElementById('zeen-input');
      if (inp) {
        inp.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); zeenSendMessage(); }
        });
      }
    });
  </script>
