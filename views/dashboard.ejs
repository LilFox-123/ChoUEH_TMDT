<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard - Chợ UEH</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/css/custom.css" rel="stylesheet"/>
  <script>tailwind.config={darkMode:"class",theme:{extend:{colors:{"primary":"#00464d","primary-container":"#005f69","primary-fixed":"#a7eefa","secondary":"#35618c","tertiary":"#712600","tertiary-fixed":"#ffdbce","surface":"#f2fbfc","surface-container-lowest":"#ffffff","surface-container-low":"#ecf5f6","surface-container":"#e7f0f0","surface-container-high":"#e1eaeb","on-surface":"#151d1e","on-surface-variant":"#3f484a","outline":"#6f797a","outline-variant":"#bec8ca","background":"#f2fbfc","error":"#ba1a1a","accent":"#EC6D33","ueh-green":"#2ecc71","ueh-green-deep":"#27ae60"},fontFamily:{"headline":["Plus Jakarta Sans"],"body":["Inter"]},borderRadius:{"DEFAULT":"0.25rem","lg":"0.5rem","xl":"0.75rem","full":"9999px"}}}}</script>
</head>
<body class="bg-background text-on-surface">

<%- include('partials/navbar') %>

<main class="pt-24 pb-16 max-w-7xl mx-auto px-6">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-extrabold text-primary">Dashboard</h1>
      <p class="text-on-surface-variant mt-1">Quản lý tin đăng và thống kê của bạn</p>
    </div>
    <a href="/post-ad" class="bg-accent text-white px-6 py-3 rounded-xl font-bold shadow-md hover:brightness-110 transition-all flex items-center gap-2">
      <span class="material-symbols-outlined">add</span> Đăng tin mới
    </a>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 mb-10">
    <div class="xl:col-span-2">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm ghost-border">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-primary-fixed rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-primary">inventory_2</span></div>
            <span class="text-sm font-semibold text-on-surface-variant">Tổng tin đăng</span>
          </div>
          <div id="stat-total" class="text-3xl font-black text-on-surface">0</div>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm ghost-border">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-green-600">check_circle</span></div>
            <span class="text-sm font-semibold text-on-surface-variant">Đang hiển thị</span>
          </div>
          <div id="stat-available" class="text-3xl font-black text-green-600">0</div>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm ghost-border">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-tertiary-fixed rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-tertiary">sell</span></div>
            <span class="text-sm font-semibold text-on-surface-variant">Đã hoàn tất</span>
          </div>
          <div id="stat-sold" class="text-3xl font-black text-tertiary">0</div>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm ghost-border">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-blue-600">visibility</span></div>
            <span class="text-sm font-semibold text-on-surface-variant">Lượt xem</span>
          </div>
          <div id="stat-views" class="text-3xl font-black text-blue-600">0</div>
        </div>
      </div>

      <div class="bg-surface-container-lowest rounded-xl shadow-sm p-6 ghost-border mt-6">
        <h3 class="text-sm font-bold uppercase tracking-wider text-primary mb-4">Hành động nhanh</h3>
        <div class="grid grid-cols-3 gap-3">
          <a href="/post-ad" class="flex flex-col items-center gap-2 p-4 rounded-xl bg-primary-fixed/30 hover:bg-primary-fixed/50 transition-all group">
            <span class="material-symbols-outlined text-2xl text-primary group-hover:scale-110 transition-transform">add_circle</span>
            <span class="text-xs font-semibold text-primary text-center">Đăng tin mới</span>
          </a>
          <a href="/messages" class="flex flex-col items-center gap-2 p-4 rounded-xl bg-blue-50 hover:bg-blue-100 transition-all group">
            <span class="material-symbols-outlined text-2xl text-secondary group-hover:scale-110 transition-transform">chat</span>
            <span class="text-xs font-semibold text-secondary text-center">Xem tin nhắn</span>
          </a>
          <a href="/profile" class="flex flex-col items-center gap-2 p-4 rounded-xl bg-tertiary-fixed/30 hover:bg-tertiary-fixed/50 transition-all group">
            <span class="material-symbols-outlined text-2xl text-tertiary group-hover:scale-110 transition-transform">person</span>
            <span class="text-xs font-semibold text-tertiary text-center">Xem hồ sơ</span>
          </a>
        </div>
      </div>
    </div>

    <section class="bg-gradient-to-br from-[#e9f9ef] via-white to-[#dff5e8] border border-[#2ecc71]/20 rounded-2xl shadow-sm p-6">
      <div class="flex items-start justify-between gap-4 mb-5">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#27ae60]">UEH Green Score</p>
          <h2 class="text-2xl font-extrabold text-[#1d6f42] mt-1">Dấu ấn tái sử dụng</h2>
          <p class="text-sm text-[#3d7b58] mt-1">Theo dõi tác động xanh từ những món đồ bạn đã đưa quay lại cộng đồng UEH.</p>
        </div>
        <div class="w-12 h-12 rounded-2xl bg-[#2ecc71]/15 text-[#27ae60] flex items-center justify-center text-2xl">♻️</div>
      </div>

      <div class="grid grid-cols-3 gap-3 mb-5">
        <div class="bg-white/80 border border-[#2ecc71]/10 rounded-xl p-4">
          <div class="text-lg mb-2">♻️</div>
          <div id="green-score-items" class="text-2xl font-black text-[#1d6f42]">0</div>
          <div class="text-xs font-semibold text-[#3d7b58]">Món tái sử dụng</div>
        </div>
        <div class="bg-white/80 border border-[#2ecc71]/10 rounded-xl p-4">
          <div class="text-lg mb-2">💰</div>
          <div id="green-score-money" class="text-2xl font-black text-[#1d6f42]">0đ</div>
          <div class="text-xs font-semibold text-[#3d7b58]">Ước tính tiết kiệm</div>
        </div>
        <div class="bg-white/80 border border-[#2ecc71]/10 rounded-xl p-4">
          <div class="text-lg mb-2">🌱</div>
          <div id="green-score-co2" class="text-2xl font-black text-[#1d6f42]">0 kg</div>
          <div class="text-xs font-semibold text-[#3d7b58]">CO2 giảm</div>
        </div>
      </div>

      <div class="bg-white/70 rounded-xl border border-[#2ecc71]/10 p-4">
        <div class="flex items-center justify-between gap-3 mb-3">
          <div>
            <p class="text-sm font-semibold text-[#3d7b58]">Cấp độ hiện tại</p>
            <div id="green-score-level" class="text-lg font-extrabold text-[#1d6f42]">Xanh Mới</div>
          </div>
          <div id="green-score-level-badge" class="px-3 py-1 rounded-full bg-[#2ecc71]/15 text-[#27ae60] text-xs font-bold">0 món</div>
        </div>
        <div class="w-full h-3 bg-[#2ecc71]/15 rounded-full overflow-hidden">
          <div id="green-score-progress" class="h-full rounded-full bg-gradient-to-r from-[#2ecc71] to-[#27ae60] transition-all duration-500" style="width: 0%"></div>
        </div>
        <p id="green-score-progress-text" class="text-xs text-[#3d7b58] font-medium mt-3">Bạn đang ở cấp Xanh Mới.</p>
      </div>
    </section>
  </div>

  <h2 class="text-xl font-bold mb-6">Tin đăng của bạn</h2>
  <div id="my-products" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    <div class="skeleton h-64 rounded-xl"></div>
    <div class="skeleton h-64 rounded-xl"></div>
    <div class="skeleton h-64 rounded-xl"></div>
    <div class="skeleton h-64 rounded-xl"></div>
  </div>
  <div id="no-products" class="hidden text-center py-16">
    <span class="material-symbols-outlined text-6xl text-outline-variant mb-4 block">storefront</span>
    <p class="text-lg font-semibold text-on-surface-variant">Bạn chưa có tin đăng nào</p>
    <a href="/post-ad" class="inline-block mt-4 bg-primary text-white px-6 py-3 rounded-xl font-bold hover:bg-primary-container transition-all">Đăng tin ngay</a>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl mx-auto mt-8">
      <a href="/post-ad" class="p-5 rounded-xl border-2 border-primary/20 hover:border-primary hover:bg-primary-fixed/10 transition-all text-left">
        <div class="flex items-center gap-3 mb-2">
          <span class="material-symbols-outlined text-primary">sell</span>
          <h4 class="font-bold text-on-surface">Đăng bài bán đồ</h4>
        </div>
        <p class="text-sm text-on-surface-variant">Pass lại giáo trình, thiết bị hoặc đồ dùng cho sinh viên khác</p>
      </a>
      <a href="/post-ad" class="p-5 rounded-xl border-2 border-[#c68a00]/20 hover:border-[#c68a00] hover:bg-[#fff8e8] transition-all text-left">
        <div class="flex items-center gap-3 mb-2">
          <span class="material-symbols-outlined text-[#c68a00]">search</span>
          <h4 class="font-bold text-on-surface">Đăng bài đang cần</h4>
        </div>
        <p class="text-sm text-on-surface-variant">Chọn "Đang cần" để người khác biết bạn đang tìm gì</p>
      </a>
    </div>
  </div>

  <div class="mt-10 bg-surface-container-low rounded-xl p-6 border-2 border-dashed border-outline-variant/30 text-center">
    <p class="text-on-surface-variant font-medium">📊 Thống kê chi tiết sắp ra mắt — Theo dõi lượt xem từng bài đăng và tỷ lệ phản hồi</p>
  </div>
</main>

<%- include('partials/footer') %>

<div id="toast-container" class="toast-container"></div>
<script src="/js/app.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>
