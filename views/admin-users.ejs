<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Quản lý Người dùng - Admin</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/css/custom.css" rel="stylesheet"/>
  <script>tailwind.config={theme:{extend:{colors:{"primary":"#00464d","primary-container":"#005f69","surface":"#f2fbfc","on-surface":"#151d1e","on-surface-variant":"#3f484a","outline":"#6f797a","accent":"#EC6D33"},fontFamily:{"headline":["Plus Jakarta Sans"],"body":["Inter"]}}}}</script>
  <style>
    #admin-mobile-bar { display: flex; }
    #admin-sidebar { transform: translateX(-100%); }
    #admin-main { margin-left: 0; padding: 1rem; padding-top: 4rem; }
    @media (min-width: 1024px) {
      #admin-mobile-bar { display: none; }
      #admin-sidebar { transform: translateX(0); }
      #admin-main { margin-left: 16rem; padding: 2rem; }
    }
  </style>
</head>
<body class="bg-[#f0f4f8] text-on-surface min-h-screen">

<!-- Mobile top bar -->
<div id="admin-mobile-bar" class="fixed top-0 left-0 right-0 z-50 bg-[#0f2027] px-4 py-3 items-center justify-between">
  <a href="/" class="cho-ueh-logo logo-white">
    <div class="logo-emblem"><svg width="18" height="18" viewBox="0 0 22 22" fill="none"><path d="M11 3L2 7.5L11 12L20 7.5L11 3Z" fill="white" opacity="0.95"/><path d="M5 9.5V14.5C5 14.5 7.5 17 11 17C14.5 17 17 14.5 17 14.5V9.5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/></svg></div>
    <div class="logo-wordmark"><span class="logo-cho">Chợ</span><span class="logo-ueh-text">UEH<span class="accent-dot">.</span></span></div>
  </a>
  <button id="sidebar-toggle" class="text-white p-2 rounded-lg transition-all" style="background:transparent;border:none;cursor:pointer;">
    <span class="material-symbols-outlined">menu</span>
  </button>
</div>
<div id="sidebar-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:40;"></div>

<div class="flex min-h-screen">
  <!-- Sidebar -->
  <aside id="admin-sidebar" class="w-64 bg-[#0f2027] text-white flex flex-col fixed h-full z-50" style="transition:transform 0.3s;">
    <div class="p-6 border-b border-white/10">
      <a href="/" class="cho-ueh-logo logo-white">
        <div class="logo-emblem"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 3L2 7.5L11 12L20 7.5L11 3Z" fill="white" opacity="0.95"/><path d="M5 9.5V14.5C5 14.5 7.5 17 11 17C14.5 17 17 14.5 17 14.5V9.5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/></svg></div>
        <div class="logo-wordmark"><span class="logo-cho">Chợ</span><span class="logo-ueh-text">UEH<span class="accent-dot">.</span></span></div>
      </a>
      <p class="text-xs text-white/40 mt-2 uppercase tracking-widest font-bold">Admin Panel</p>
    </div>
    <nav class="flex-1 p-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/70 hover:text-white font-medium text-sm transition-all"><span class="material-symbols-outlined text-lg">dashboard</span>Dashboard</a>
      <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white/10 text-white font-semibold text-sm"><span class="material-symbols-outlined text-lg">group</span>Người dùng</a>
      <a href="/admin/products" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/70 hover:text-white font-medium text-sm transition-all"><span class="material-symbols-outlined text-lg">inventory_2</span>Sản phẩm</a>
      <div class="border-t border-white/10 my-4"></div>
      <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/70 hover:text-white font-medium text-sm transition-all"><span class="material-symbols-outlined text-lg">home</span>Về trang chủ</a>
    </nav>
  </aside>

  <main id="admin-main" class="flex-1">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-extrabold text-[#0f2027]">Quản lý Người dùng</h1>
        <p class="text-on-surface-variant mt-1">Xem, chỉnh sửa và quản lý tài khoản</p>
      </div>
      <div class="relative w-72">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
        <input id="user-search" class="w-full pl-10 pr-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none" placeholder="Tìm theo tên, email, MSSV..." type="text"/>
      </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Người dùng</th>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">MSSV</th>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Khoa</th>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Vai trò</th>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Ngày tạo</th>
            <th class="text-right px-6 py-4 font-semibold text-gray-500">Hành động</th>
          </tr>
        </thead>
        <tbody id="users-table">
          <tr><td colspan="6" class="px-6 py-8 text-center text-gray-400"><span class="spinner spinner-lg"></span></td></tr>
        </tbody>
      </table>
    </div>
    <div id="users-pagination" class="mt-6 flex justify-center gap-2"></div>
  </main>
</div>

<!-- Edit User Modal -->
<div id="edit-user-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[999] hidden flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg">
    <div class="flex items-center justify-between p-6 border-b border-gray-100">
      <h3 class="text-xl font-bold">Chỉnh sửa người dùng</h3>
      <button onclick="closeEditUserModal()" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors"><span class="material-symbols-outlined">close</span></button>
    </div>
    <form id="edit-user-form" class="p-6 space-y-4">
      <input type="hidden" id="edit-user-id"/>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-xs font-semibold text-gray-500 mb-1">Họ tên</label><input id="edit-user-name" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="text"/></div>
        <div><label class="block text-xs font-semibold text-gray-500 mb-1">Email</label><input id="edit-user-email" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="email"/></div>
        <div><label class="block text-xs font-semibold text-gray-500 mb-1">Điện thoại</label><input id="edit-user-phone" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="tel"/></div>
        <div><label class="block text-xs font-semibold text-gray-500 mb-1">Vai trò</label>
          <select id="edit-user-role" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm">
            <option value="user">User</option><option value="admin">Admin</option>
          </select>
        </div>
        <div><label class="block text-xs font-semibold text-gray-500 mb-1">Khoa</label><input id="edit-user-department" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="text"/></div>
        <div><label class="block text-xs font-semibold text-gray-500 mb-1">Khóa</label><input id="edit-user-year" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="text"/></div>
      </div>
      <div class="flex justify-end gap-3 pt-4">
        <button type="button" onclick="closeEditUserModal()" class="px-5 py-2.5 bg-gray-100 text-gray-600 rounded-lg font-semibold text-sm hover:bg-gray-200 transition-colors">Hủy</button>
        <button type="submit" class="px-5 py-2.5 bg-primary text-white rounded-lg font-semibold text-sm hover:bg-primary-container transition-colors">Lưu thay đổi</button>
      </div>
    </form>
  </div>
</div>

<div id="toast-container" class="toast-container"></div>
<script src="/js/app.js"></script>
<script src="/js/admin.js"></script>
<script>document.addEventListener('DOMContentLoaded', () => window.AdminApp && window.AdminApp.initUsers());</script>
<script>
(function() {
  var toggle = document.getElementById('sidebar-toggle');
  var sidebar = document.getElementById('admin-sidebar');
  var overlay = document.getElementById('sidebar-overlay');
  function openSidebar() {
    sidebar.style.transform = 'translateX(0)';
    overlay.style.display = 'block';
  }
  function closeSidebar() {
    sidebar.style.transform = 'translateX(-100%)';
    overlay.style.display = 'none';
  }
  if (toggle) toggle.addEventListener('click', openSidebar);
  if (overlay) overlay.addEventListener('click', closeSidebar);
  var navLinks = sidebar ? sidebar.querySelectorAll('a') : [];
  navLinks.forEach(function(link) {
    link.addEventListener('click', function() {
      if (window.innerWidth < 1024) closeSidebar();
    });
  });
})();
</script>
</body>
</html>
