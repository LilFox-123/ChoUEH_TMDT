                  <span id="stat-sidebar-wanted" class="text-sm font-bold text-on-surface">–</span>
                </div>
                <div class="flex items-center justify-between py-2">
                  <span class="flex items-center gap-2 text-xs text-on-surface-variant"><span
                      class="material-symbols-outlined text-sm text-[#27ae60]">check_circle</span>Đã giao dịch</span>
