                    style="animation: zeenFloat 3.5s ease-in-out 0.5s infinite;">
                    <p class="text-[10px] font-bold uppercase tracking-wide opacity-80">Giá từ</p>
                    <p class="text-xl font-black leading-none">50K</p>
                    <p class="text-[10px] opacity-80 mt-0.5">/ cuốn sách</p>
                  </div>
                  <!-- Category badge bottom-left -->
