<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chợ UEH - Mua bán thông minh cho sinh viên</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    rel="stylesheet" />
  <link href="/css/custom.css" rel="stylesheet" />
  <script>
    tailwind.config = { darkMode: "class", theme: { extend: { colors: { "primary": "#00464d", "primary-container": "#005f69", "primary-fixed": "#a7eefa", "primary-fixed-dim": "#8bd2dd", "on-primary": "#ffffff", "on-primary-container": "#8fd6e2", "secondary": "#35618c", "secondary-container": "#a2cdfe", "secondary-fixed": "#d0e4ff", "on-secondary-fixed": "#001d35", "tertiary": "#712600", "tertiary-container": "#973600", "tertiary-fixed": "#ffdbce", "tertiary-fixed-dim": "#ffb598", "on-tertiary": "#ffffff", "on-tertiary-container": "#ffbca1", "surface": "#f2fbfc", "surface-dim": "#d3dcdd", "surface-container-lowest": "#ffffff", "surface-container-low": "#ecf5f6", "surface-container": "#e7f0f0", "surface-container-high": "#e1eaeb", "surface-container-highest": "#dbe4e5", "surface-variant": "#dbe4e5", "on-surface": "#151d1e", "on-surface-variant": "#3f484a", "outline": "#6f797a", "outline-variant": "#bec8ca", "background": "#f2fbfc", "on-background": "#151d1e", "inverse-surface": "#293233", "inverse-primary": "#8bd2dd" }, fontFamily: { "headline": ["Plus Jakarta Sans", "sans-serif"], "body": ["Inter", "sans-serif"], "display": ["Playfair Display", "Georgia", "serif"] } } } }
  </script>
  <style>
    @keyframes zeenFloat {

      0%,
      100% {
        transform: translateY(0px) rotate(-1deg);
      }

      50% {
        transform: translateY(-10px) rotate(1deg);
      }
    }

    @keyframes zeenWave {

      0%,
      100% {
        transform: rotate(0deg);
        transform-origin: 70% 70%;
      }

      10%,
      30% {
        transform: rotate(-10deg);
        transform-origin: 70% 70%;
      }

      20%,
      40% {
        transform: rotate(10deg);
        transform-origin: 70% 70%;
      }

      50% {
        transform: rotate(0deg);
        transform-origin: 70% 70%;
      }
    }

    @keyframes zeenGlow {

      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(0, 70, 77, 0);
      }

      50% {
        box-shadow: 0 0 20px 4px rgba(0, 70, 77, 0.12);
      }
    }

    @keyframes bubblePop {
      0% {
        opacity: 0;
        transform: scale(0.8) translateY(4px);
      }

      60% {
        opacity: 1;
        transform: scale(1.05) translateY(-2px);
      }

      100% {
        opacity: 1;
        transform: scale(1) translateY(0);
      }
    }

    @keyframes dotBlink {

      0%,
      100% {
        opacity: 1;
      }

      50% {
        opacity: 0.3;
      }
    }

    @keyframes countUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideInLeft {
      from {
        opacity: 0;
        transform: translateX(-40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes slideInRight {
      from {
        opacity: 0;
        transform: translateX(40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes progressFill {
      from {
        width: 0%;
      }
    }

    @keyframes pulseRing {
      0% {
        transform: scale(1);
        opacity: 0.6;
      }

      100% {
        transform: scale(1.6);
        opacity: 0;
      }
    }

    .anim-hidden {
      opacity: 0;
    }

    .anim-slide-left {
      animation: slideInLeft 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .anim-slide-right {
      animation: slideInRight 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .anim-fade-up {
      animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
  </style>
</head>

<body class="bg-background text-on-surface">

  <%- include('partials/navbar') %>

    <main class="pt-16">
      <!-- HERO SLIDER -->
      <section class="relative h-[520px] md:h-[560px] overflow-hidden" id="hero-slider">
