                    <p class="text-xs text-on-surface-variant">Rác còn lại: túi nilon bẩn, xốp, ống hút...</p>
                  </div>
                </div>
              </div>
              <div class="flex justify-center gap-1.5 mt-3">
                <span class="waste-dot w-2 h-2 rounded-full bg-primary transition-all" data-index="0"></span>
                <span class="waste-dot w-2 h-2 rounded-full bg-outline-variant transition-all" data-index="1"></span>
                <span class="waste-dot w-2 h-2 rounded-full bg-outline-variant transition-all" data-index="2"></span>
                <span class="waste-dot w-2 h-2 rounded-full bg-outline-variant transition-all" data-index="3"></span>
              </div>
            </div>

            <!-- Widget: UEH Green Campus Promo -->
            <div
              class="bg-gradient-to-br from-green-50 to-emerald-100 p-5 rounded-xl border border-green-200 text-center">
              <div
                class="w-14 h-14 mx-auto mb-3 rounded-full bg-white flex items-center justify-center text-3xl shadow-sm"
                style="animation: zeenFloat 3s ease-in-out infinite;">
                🌱
              </div>
              <p class="text-xs font-bold text-green-800 uppercase tracking-wide mb-1">Zeen đồng hành cùng bạn</p>
              <h4 class="font-black text-primary text-sm mb-2">UEH Green Campus</h4>
              <p class="text-xs text-green-700 italic mb-3">"From Circular Waste to Green Campus"</p>
              <a href="https://gogreen.ueh.edu.vn" target="_blank" rel="noopener"
                class="inline-flex items-center justify-center gap-1 w-full bg-primary text-white text-xs font-bold px-4 py-2 rounded-lg hover:brightness-110 transition-all">
                Khám phá ngay
                <span class="material-symbols-outlined text-sm">open_in_new</span>
              </a>
            </div>

          </aside>

          <script>
              // Waste tip rotation
              (function initWasteTipRotation() {
                const tips = document.querySelectorAll('#waste-tip-widget .waste-tip-item');
                const dots = document.querySelectorAll('.waste-dot');
                if (!tips.length) return;
                let current = 0;
                function showTip(index) {
                  tips.forEach((t, i) => {
                    t.classList.toggle('hidden', i !== index);
                    t.classList.toggle('flex', i === index);
                  });
                  dots.forEach((d, i) => {
                    d.classList.toggle('bg-primary', i === index);
                    d.classList.toggle('bg-outline-variant', i !== index);
                  });
                }
                setInterval(() => {
                  current = (current + 1) % tips.length;
                  showTip(current);
                }, 3000);
              })();
          </script>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>

      <div id="toast-container" class="toast-container"></div>

      <script src="/js/app.js"></script>
      <script src="/js/products.js"></script>
      <script>
        // ── Hero Slider ──
        let currentSlide = 0;
        const totalSlides = 3;
        let heroInterval;

        function goToSlide(index) {
          const slides = document.querySelectorAll('.hero-slide');
          const dots = document.querySelectorAll('.hero-dot');

          slides.forEach((s, i) => {
            if (i === index) {
              s.style.opacity = '1';
              s.style.zIndex = '10';
              s.style.transform = 'scale(1)';
              // Animate content
              const content = s.querySelector('.hero-content');
              if (content) { content.style.transform = 'translateY(0)'; content.style.opacity = '1'; }
            } else {
              s.style.opacity = '0';
              s.style.zIndex = '0';
              s.style.transform = 'scale(1.05)';
              const content = s.querySelector('.hero-content');
              if (content) { content.style.transform = 'translateY(30px)'; content.style.opacity = '0'; }
            }
          });
          dots.forEach((d, i) => {
            d.className = i === index
              ? 'hero-dot w-10 h-1.5 rounded-full bg-white/80 transition-all duration-300'
              : 'hero-dot w-6 h-1.5 rounded-full bg-white/30 transition-all duration-300';
          });
          currentSlide = index;

          // Animate counters on slide 3
          if (index === 2) animateCounters();

          resetHeroInterval();
        }

        function nextSlide() { goToSlide((currentSlide + 1) % totalSlides); }
        function prevSlide() { goToSlide((currentSlide - 1 + totalSlides) % totalSlides); }

        function resetHeroInterval() {
          clearInterval(heroInterval);
          heroInterval = setInterval(nextSlide, 5000);
        }

        // Counter animation
        function animateCounters() {
          document.querySelectorAll('.hero-counter').forEach(el => {
            const target = parseInt(el.dataset.target);
            if (!target) return;
            let current = 0;
            const step = target / 60;
            const timer = setInterval(() => {
              current += step;
              if (current >= target) { el.textContent = target.toLocaleString('vi-VN'); clearInterval(timer); return; }
              el.textContent = Math.floor(current).toLocaleString('vi-VN');
            }, 25);
          });
        }

        // Init hero content transitions
        document.querySelectorAll('.hero-content').forEach(c => {
          c.style.transition = 'transform 0.8s cubic-bezier(0.16,1,0.3,1), opacity 0.6s ease';
        });

        // Start auto-play
        heroInterval = setInterval(nextSlide, 5000);

        // Load featured products on homepage
        document.addEventListener('DOMContentLoaded', async () => {
          try {
            const res = await fetch('/api/products?limit=8&listingType=sell');
            const data = await res.json();
            const container = document.getElementById('featured-products');
            if (data.success && data.data.length > 0) {
              container.innerHTML = data.data.map(p => window.AppUtils.productCard(p)).join('');
            } else {
              container.innerHTML = '<p class="col-span-full text-center text-on-surface-variant py-8">Chưa có sản phẩm nào. Hãy đăng tin đầu tiên!</p>';
            }
          } catch (err) {
            console.error('Failed to load products:', err);
            document.getElementById('featured-products').innerHTML = '<p class="col-span-full text-center text-on-surface-variant py-8">Không thể tải sản phẩm</p>';
          }
        });

        // Load wanted board
        (async function loadWantedBoard() {
          const container = document.getElementById('homepage-wanted-board');
          if (!container) return;
          try {
            const res = await fetch('/api/products?listingType=wanted&limit=3&status=available');
            const data = await res.json();
            if (!data.success || !data.data.length) {
              container.innerHTML = '<p class="col-span-3 text-center text-sm text-on-surface-variant py-6">Chưa có nhu cầu nào.</p>';
              return;
            }
            const urgencyMap = { high: '🔴 Cần gấp', medium: '🟡 Trong tuần', low: '🟢 Chưa gấp' };
            container.innerHTML = data.data.map(p => {
              const esc = window.AppUtils?.esc || (s => s.replace(/</g, '&lt;'));
              const badge = p.courseCode ? `<span class="px-2 py-0.5 rounded-full bg-[#fff3dc] text-[#c68a00] text-xs font-bold">${esc(p.courseCode)}</span>` : '';
              const faculty = p.faculty ? `<span class="px-2 py-0.5 rounded-full bg-primary-fixed/40 text-primary text-xs font-semibold">${esc(p.faculty)}</span>` : '';
              const urgency = urgencyMap[p.urgency] || '🟡 Trong tuần';
              const budget = (p.budgetMin || p.budgetMax)
                ? `${(p.budgetMin || 0).toLocaleString('vi-VN')}đ – ${(p.budgetMax || 0).toLocaleString('vi-VN')}đ`
                : 'Thương lượng';
              return `<div class="bg-[#fff8e8] border border-[#f4ddb0] rounded-xl p-4 flex flex-col gap-2 hover:shadow-md transition-shadow">
          <div class="flex flex-wrap gap-1">${badge}${faculty}</div>
          <p class="font-semibold text-sm text-on-surface line-clamp-2">${esc(p.title)}</p>
          <div class="flex items-center justify-between mt-auto pt-2">
            <span class="text-xs text-[#c68a00] font-medium">${urgency}</span>
            <span class="text-xs text-on-surface-variant">${budget}</span>
          </div>
          <a href="/products?listingType=wanted" class="block w-full text-center bg-[#c68a00] text-white text-xs font-bold py-2 rounded-lg hover:brightness-110 transition-all mt-1">Tôi có món này</a>
        </div>`;
            }).join('');
          } catch (e) {
            container.innerHTML = '<p class="col-span-3 text-center text-sm text-on-surface-variant py-6">Không thể tải dữ liệu.</p>';
          }
        })();

        // Load sidebar stats
        (async function loadSidebarStats() {
          try {
            const [sellRes, wantedRes, soldRes] = await Promise.all([
              fetch('/api/products?listingType=sell&status=available&limit=1'),
              fetch('/api/products?listingType=wanted&status=available&limit=1'),
              fetch('/api/products?status=sold&limit=1')
            ]);
            const [sellData, wantedData, soldData] = await Promise.all([sellRes.json(), wantedRes.json(), soldRes.json()]);
            const el = (id) => document.getElementById(id);
            if (sellData.success && el('stat-sidebar-products')) el('stat-sidebar-products').textContent = (sellData.pagination?.total || 0) + ' tin';
            if (wantedData.success && el('stat-sidebar-wanted')) el('stat-sidebar-wanted').textContent = (wantedData.pagination?.total || 0) + ' tin';
            if (soldData.success && el('stat-sidebar-sold')) el('stat-sidebar-sold').textContent = (soldData.pagination?.total || 0) + ' tin';
          } catch (e) { /* stats không hiển thị nếu lỗi */ }
        })();

        // === Scroll animations ===
        (function initScrollAnimations() {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (!entry.isIntersecting) return;
              const el = entry.target;
              const anim = el.dataset.anim;
              const delay = parseInt(el.dataset.delay || 0);
              setTimeout(() => {
                el.classList.remove('anim-hidden');
                if (anim === 'slide-left') el.classList.add('anim-slide-left');
                if (anim === 'slide-right') el.classList.add('anim-slide-right');
                if (anim === 'fade-up') el.classList.add('anim-fade-up');
                // Trigger progress bars
                el.querySelectorAll('.progress-bar').forEach(bar => {
                  bar.style.width = bar.dataset.width || '0%';
                });
              }, delay);
              observer.unobserve(el);
            });
          }, { threshold: 0.15 });
          document.querySelectorAll('[data-anim]').forEach(el => observer.observe(el));

          // Animated counter for saving
          const counterEl = document.getElementById('saving-counter');
          if (counterEl) {
            const counterObserver = new IntersectionObserver(entries => {
              if (!entries[0].isIntersecting) return;
              let val = 0; const target = 60000000;
              const step = target / 80;
              const timer = setInterval(() => {
                val += step;
                if (val >= target) { val = target; clearInterval(timer); }
                counterEl.textContent = new Intl.NumberFormat('vi-VN').format(Math.floor(val)) + 'đ';
              }, 20);
              counterObserver.unobserve(counterEl);
            }, { threshold: 0.5 });
            counterObserver.observe(counterEl);
          }
        })();
      </script>
</body>

</html>