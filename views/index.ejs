          <button class="hero-dot w-6 h-1.5 rounded-full bg-white/30 transition-all duration-300" data-slide="2"
            onclick="goToSlide(2)"></button>
        </div>

        <!-- Prev/Next arrows -->
        <button onclick="prevSlide()"
          class="absolute left-4 top-1/2 -translate-y-1/2 z-30 w-10 h-10 bg-white/10 backdrop-blur-md rounded-full flex items-center justify-center text-white hover:bg-white/25 transition-all"><span
