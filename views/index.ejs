            </div>

            <div class="bg-surface-container-low p-6 rounded-xl space-y-6">
              <h3 class="font-bold text-lg text-primary">Bộ lọc</h3>
              <div>
                <label class="block text-sm font-semibold mb-3 text-on-surface-variant">Danh mục</label>
                <div class="space-y-2">
                  <a href="/products?category=sach"
                    class="flex items-center gap-3 text-sm cursor-pointer group hover:text-primary transition-colors"><span
                      class="material-symbols-outlined text-sm">book</span>Sách & Tài liệu</a>
                  <a href="/products?category=dien-tu"
                    class="flex items-center gap-3 text-sm cursor-pointer group hover:text-primary transition-colors"><span
