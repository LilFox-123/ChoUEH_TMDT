<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Đăng Nhập | Chợ UEH</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/css/custom.css" rel="stylesheet"/>
  <script>tailwind.config={darkMode:"class",theme:{extend:{colors:{"primary":"#00464d","primary-container":"#005f69","primary-fixed":"#a7eefa","on-primary":"#ffffff","secondary":"#35618c","secondary-fixed":"#d0e4ff","tertiary":"#712600","tertiary-fixed":"#ffdbce","surface":"#f2fbfc","surface-container-lowest":"#ffffff","surface-container-low":"#ecf5f6","surface-container":"#e7f0f0","surface-container-high":"#e1eaeb","on-surface":"#151d1e","on-surface-variant":"#3f484a","outline":"#6f797a","outline-variant":"#bec8ca","background":"#f2fbfc","inverse-surface":"#293233"},fontFamily:{"headline":["Plus Jakarta Sans"],"body":["Inter"]},borderRadius:{"DEFAULT":"0.25rem","lg":"0.5rem","xl":"0.75rem","full":"9999px"}}}}</script>
</head>
<body class="bg-background text-on-surface min-h-screen flex items-center justify-center p-0 md:p-4">
<main class="w-full max-w-6xl min-h-[800px] bg-surface-container-lowest rounded-none md:rounded-3xl shadow-xl overflow-hidden flex flex-col md:flex-row">
  <!-- LEFT PANEL -->
  <section class="hidden md:flex md:w-1/2 bg-primary relative flex-col justify-between p-12 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-container to-primary-fixed/20 opacity-90 z-10"></div>
    <img alt="UEH Campus" class="absolute inset-0 object-cover w-full h-full" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAIXP7lIhTvSUSjpCFYRTvsQWY7ePkMQ5dwVM1zJ_ljrw_4_NoLkeyi_k_OyA3mFafvuswhAm1jWeIx16B47Ta66gM4MTWxXTe9F3oprUoEMIUHLoANzent_-0bQpMYcxvGB_3UUNh6MOPLxsEAm7yOLD2gxGf7seHcAilb5vyn-b4rInD6dUrfDfSAgIKscnaasIKa6L-Ilf3ZAJRMjz9fyIA7FjWmfOvctZ3qfSgPOfKlia7fzgu8Yb3J-WzvR98zADkY8s8_wTY"/>
    <div class="relative z-20">
      <a href="/" class="cho-ueh-logo logo-white mb-8 inline-flex">
        <div class="logo-emblem"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 3L2 7.5L11 12L20 7.5L11 3Z" fill="white" opacity="0.95"/><path d="M5 9.5V14.5C5 14.5 7.5 17 11 17C14.5 17 17 14.5 17 14.5V9.5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/><line x1="18.5" y1="8" x2="18.5" y2="13" stroke="white" stroke-width="1.8" stroke-linecap="round"/><circle cx="18.5" cy="7" r="1.5" fill="white"/></svg></div>
        <div class="logo-wordmark"><span class="logo-cho">Chợ</span><span class="logo-ueh-text">UEH<span class="accent-dot">.</span></span></div>
      </a>
      <h1 class="text-5xl font-extrabold leading-tight tracking-tighter mb-6">Sàn giao dịch<br/>Nội bộ UEH</h1>
      <p class="text-lg text-primary-fixed/80 max-w-md font-medium leading-relaxed">Nơi kết nối cộng đồng sinh viên Kinh tế qua những món đồ cũ giá trị.</p>
    </div>
    <div class="relative z-20 mt-auto">
      <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/20">
        <p class="text-sm font-semibold">+15,000 sinh viên tham gia</p>
        <blockquote class="text-sm italic text-white/90 mt-2">"Mình đã tìm được giáo trình hiếm và pass laptop cũ chỉ trong 2 ngày trên Chợ UEH!"</blockquote>
      </div>
    </div>
  </section>

  <!-- RIGHT PANEL -->
  <section class="w-full md:w-1/2 flex flex-col justify-center p-8 md:p-16 bg-surface-container-lowest">
    <div class="max-w-md mx-auto w-full">
      <div class="mb-10">
        <h2 class="text-3xl font-extrabold text-primary-container tracking-tight mb-2">Chào mừng trở lại! 👋</h2>
        <p class="text-on-surface-variant font-medium">Chưa có tài khoản? <a class="text-tertiary font-semibold hover:underline" href="/register">Đăng ký miễn phí</a></p>
      </div>
      <div class="mb-8 p-4 bg-primary-container/10 rounded-xl border-l-4 border-primary-container flex items-start gap-3">
        <span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">info</span>
        <p class="text-sm font-semibold text-primary-container leading-snug">Sử dụng email UEH hoặc MSSV để đăng nhập.</p>
      </div>

      <form id="login-form" class="space-y-6">
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2" for="email">Email UEH hoặc MSSV</label>
          <div class="relative group">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">alternate_email</span>
            <input class="w-full pl-12 pr-4 py-3.5 bg-surface-container-high rounded-xl border-none ring-1 ring-outline-variant/30 focus:ring-2 focus:ring-primary focus:bg-surface-container-lowest transition-all outline-none font-medium placeholder:text-outline/60" id="email" placeholder="2224102... hoặc email@st.ueh.edu.vn" type="text" required/>
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2" for="password">Mật khẩu</label>
          <div class="relative group">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">lock</span>
            <input class="w-full pl-12 pr-12 py-3.5 bg-surface-container-high rounded-xl border-none ring-1 ring-outline-variant/30 focus:ring-2 focus:ring-primary focus:bg-surface-container-lowest transition-all outline-none font-medium placeholder:text-outline/60" id="password" placeholder="••••••••" type="password" required/>
          </div>
        </div>
        <div id="login-error" class="hidden p-3 bg-red-50 text-red-700 rounded-lg text-sm font-medium"></div>
        <button class="w-full py-4 bg-gradient-to-br from-primary to-primary-container text-white font-bold rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.01] active:scale-[0.98] transition-all flex items-center justify-center gap-2" type="submit" id="login-btn">
          Đăng Nhập
          <span class="material-symbols-outlined">arrow_forward</span>
        </button>
      </form>
      <div class="mt-12 text-center">
        <p class="text-xs text-outline font-medium">© 2026 UEH | Chợ UEH Marketplace</p>
      </div>
    </div>
  </section>
</main>

<div id="toast-container" class="toast-container"></div>
<script src="/js/app.js"></script>
<script src="/js/auth.js"></script>
</body>
</html>
