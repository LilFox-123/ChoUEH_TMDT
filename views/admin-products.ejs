<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Quản lý Sản phẩm - Admin</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/css/custom.css" rel="stylesheet"/>
  <script>tailwind.config={theme:{extend:{colors:{"primary":"#00464d","primary-container":"#005f69","surface":"#f2fbfc","on-surface":"#151d1e","on-surface-variant":"#3f484a","outline":"#6f797a","accent":"#EC6D33"},fontFamily:{"headline":["Plus Jakarta Sans"],"body":["Inter"]}}}}</script>
  <style>
    #admin-mobile-bar { display: flex; }
    #admin-sidebar { transform: translateX(-100%); }
    #admin-main { margin-left: 0; padding: 1rem; padding-top: 4rem; }
    @media (min-width: 1024px) {
      #admin-mobile-bar { display: none; }
      #admin-sidebar { transform: translateX(0); }
      #admin-main { margin-left: 16rem; padding: 2rem; }
    }
  </style>
</head>
<body class="bg-[#f0f4f8] text-on-surface min-h-screen">

<!-- Mobile top bar -->
<div id="admin-mobile-bar" class="fixed top-0 left-0 right-0 z-50 bg-[#0f2027] px-4 py-3 items-center justify-between">
  <a href="/" class="cho-ueh-logo logo-white">
    <div class="logo-emblem"><svg width="18" height="18" viewBox="0 0 22 22" fill="none"><path d="M11 3L2 7.5L11 12L20 7.5L11 3Z" fill="white" opacity="0.95"/><path d="M5 9.5V14.5C5 14.5 7.5 17 11 17C14.5 17 17 14.5 17 14.5V9.5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/></svg></div>
    <div class="logo-wordmark"><span class="logo-cho">Chợ</span><span class="logo-ueh-text">UEH<span class="accent-dot">.</span></span></div>
  </a>
  <button id="sidebar-toggle" class="text-white p-2 rounded-lg transition-all" style="background:transparent;border:none;cursor:pointer;">
    <span class="material-symbols-outlined">menu</span>
  </button>
</div>
<div id="sidebar-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:40;"></div>

<div class="flex min-h-screen">
  <aside id="admin-sidebar" class="w-64 bg-[#0f2027] text-white flex flex-col fixed h-full z-50" style="transition:transform 0.3s;">
    <div class="p-6 border-b border-white/10">
      <a href="/" class="cho-ueh-logo logo-white">
        <div class="logo-emblem"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 3L2 7.5L11 12L20 7.5L11 3Z" fill="white" opacity="0.95"/><path d="M5 9.5V14.5C5 14.5 7.5 17 11 17C14.5 17 17 14.5 17 14.5V9.5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/></svg></div>
        <div class="logo-wordmark"><span class="logo-cho">Chợ</span><span class="logo-ueh-text">UEH<span class="accent-dot">.</span></span></div>
      </a>
      <p class="text-xs text-white/40 mt-2 uppercase tracking-widest font-bold">Admin Panel</p>
    </div>
    <nav class="flex-1 p-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/70 hover:text-white font-medium text-sm transition-all"><span class="material-symbols-outlined text-lg">dashboard</span>Dashboard</a>
      <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/70 hover:text-white font-medium text-sm transition-all"><span class="material-symbols-outlined text-lg">group</span>Người dùng</a>
      <a href="/admin/products" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-white/10 text-white font-semibold text-sm"><span class="material-symbols-outlined text-lg">inventory_2</span>Sản phẩm</a>
      <div class="border-t border-white/10 my-4"></div>
      <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/70 hover:text-white font-medium text-sm transition-all"><span class="material-symbols-outlined text-lg">home</span>Về trang chủ</a>
    </nav>
  </aside>

  <main id="admin-main" class="flex-1">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-extrabold text-[#0f2027]">Quản lý Sản phẩm</h1>
        <p class="text-on-surface-variant mt-1">Quản lý cả bài đăng bán hàng và bảng nhu cầu “Đang cần” của sinh viên UEH.</p>
      </div>
      <div class="flex gap-3">
        <select id="product-category-filter" class="px-3 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-primary outline-none">
          <option value="">Tất cả DM</option>
          <option value="sach">Sách</option><option value="dien-tu">Điện tử</option>
          <option value="do-dung">Đồ dùng</option><option value="thoi-trang">Thời trang</option>
          <option value="xe">Xe</option><option value="khac">Khác</option>
        </select>
        <div class="relative w-64">
          <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
          <input id="product-search" class="w-full pl-10 pr-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none" placeholder="Tìm sản phẩm, nhu cầu..." type="text"/>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Bài đăng</th>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Người đăng</th>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Giá / Ngân sách</th>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Danh mục</th>
            <th class="text-left px-6 py-4 font-semibold text-gray-500">Trạng thái</th>
            <th class="text-right px-6 py-4 font-semibold text-gray-500">Hành động</th>
          </tr>
        </thead>
        <tbody id="products-table">
          <tr><td colspan="6" class="px-6 py-8 text-center text-gray-400"><span class="spinner spinner-lg"></span></td></tr>
        </tbody>
      </table>
    </div>
    <div id="products-pagination" class="mt-6 flex justify-center gap-2"></div>
  </main>
</div>

<div id="edit-product-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[999] hidden flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between p-6 border-b border-gray-100 sticky top-0 bg-white z-10">
      <h3 class="text-xl font-bold">Chỉnh sửa bài đăng</h3>
      <button onclick="closeEditProductModal()" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors"><span class="material-symbols-outlined">close</span></button>
    </div>

    <form id="edit-product-form" enctype="multipart/form-data" class="p-6 space-y-4">
      <input type="hidden" id="edit-product-id"/>
      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-gray-500 mb-1">Tiêu đề</label>
          <input id="edit-product-title" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="text"/>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 mb-1">Loại bài đăng</label>
          <select id="edit-product-listing-type" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm">
            <option value="sell">Đang bán</option>
            <option value="wanted">Đang cần</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 mb-1">Danh mục</label>
          <select id="edit-product-category" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm">
            <option value="sach">Sách</option><option value="dien-tu">Điện tử</option>
            <option value="do-dung">Đồ dùng</option><option value="thoi-trang">Thời trang</option>
            <option value="xe">Xe</option><option value="khac">Khác</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 mb-1">Giá bán (VNĐ)</label>
          <input id="edit-product-price" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="number"/>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 mb-1">Ngân sách từ</label>
          <input id="edit-product-budget-min" class="w-full px-3 py-2.5 bg-[#fff8e8] rounded-lg border border-[#f4ddb0] focus:ring-2 focus:ring-[#c68a00] text-sm" type="number"/>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 mb-1">Ngân sách đến</label>
          <input id="edit-product-budget-max" class="w-full px-3 py-2.5 bg-[#fff8e8] rounded-lg border border-[#f4ddb0] focus:ring-2 focus:ring-[#c68a00] text-sm" type="number"/>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 mb-1">Mức độ gấp</label>
          <select id="edit-product-urgency" class="w-full px-3 py-2.5 bg-[#fff8e8] rounded-lg border border-[#f4ddb0] focus:ring-2 focus:ring-[#c68a00] text-sm">
            <option value="medium">Cần trong tuần</option>
            <option value="high">Cần gấp</option>
            <option value="low">Chưa gấp</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 mb-1">Tình trạng</label>
          <select id="edit-product-condition" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm">
            <option value="new">Mới</option><option value="used">Đã dùng</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 mb-1">Trạng thái</label>
          <select id="edit-product-status" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm">
            <option value="available">Đang hiển thị</option><option value="sold">Đã hoàn tất</option><option value="reserved">Đang trao đổi</option>
          </select>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-gray-500 mb-1">Mô tả</label>
          <textarea id="edit-product-description" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm resize-none" rows="3"></textarea>
        </div>
      </div>

      <div class="border-t border-gray-100 pt-4">
        <h4 class="text-sm font-bold text-primary mb-3">Ngữ cảnh học phần UEH</h4>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-xs font-semibold text-gray-500 mb-1">Mã môn học</label><input id="edit-product-course-code" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm uppercase" type="text"/></div>
          <div><label class="block text-xs font-semibold text-gray-500 mb-1">Tên môn học</label><input id="edit-product-course-name" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="text"/></div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Khoa</label>
            <select id="edit-product-faculty" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm">
              <option value="">Chọn khoa</option>
              <option value="Kế toán">Kế toán</option>
              <option value="Kinh tế">Kinh tế</option>
              <option value="Kinh doanh quốc tế">Kinh doanh quốc tế</option>
              <option value="Tài chính">Tài chính</option>
              <option value="Luật">Luật</option>
              <option value="Công nghệ thông tin">Công nghệ thông tin</option>
            </select>
          </div>
          <div><label class="block text-xs font-semibold text-gray-500 mb-1">Niên khóa</label><input id="edit-product-academic-year" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm" type="text" placeholder="2024-2025"/></div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 mb-1">Học kỳ</label>
            <select id="edit-product-semester" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg border-none focus:ring-2 focus:ring-primary text-sm">
              <option value="">Chọn học kỳ</option>
              <option value="1">Học kỳ 1</option>
              <option value="2">Học kỳ 2</option>
            </select>
          </div>
          <div class="col-span-2">
            <label class="block text-xs font-semibold text-gray-500 mb-2">Phù hợp với năm học</label>
            <div class="grid grid-cols-4 gap-2">
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-suitable-year" value="1" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Năm 1</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-suitable-year" value="2" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Năm 2</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-suitable-year" value="3" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Năm 3</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-suitable-year" value="4" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Năm 4</span></label>
            </div>
          </div>
          <div class="col-span-2">
            <label class="block text-xs font-semibold text-gray-500 mb-2">Điểm hẹn trong UEH</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-meeting-point" value="Cơ sở A - 59 Nguyễn Đình Chiểu" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Cơ sở A - 59 Nguyễn Đình Chiểu</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-meeting-point" value="Cơ sở B - 279 Nguyễn Tri Phương" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Cơ sở B - 279 Nguyễn Tri Phương</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-meeting-point" value="Cơ sở N - Nguyễn Văn Linh" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Cơ sở N - Nguyễn Văn Linh</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-meeting-point" value="Thư viện" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Thư viện</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-meeting-point" value="Căn tin" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Căn tin</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-meeting-point" value="Sảnh chính" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Sảnh chính</span></label>
            </div>
          </div>
          <div class="col-span-2">
            <label class="block text-xs font-semibold text-gray-500 mb-2">Khung giờ giao nhận ưu tiên</label>
            <div class="grid grid-cols-2 gap-2">
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-preferred-time-slot" value="Sau tiết 2" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Sau tiết 2</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-preferred-time-slot" value="Sau tiết 4" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Sau tiết 4</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-preferred-time-slot" value="Buổi trưa 11h-13h" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Buổi trưa 11h-13h</span></label>
              <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 text-sm"><input type="checkbox" name="edit-preferred-time-slot" value="Buổi chiều 15h-17h" class="rounded border-gray-300 text-primary focus:ring-primary"/><span>Buổi chiều 15h-17h</span></label>
            </div>
          </div>
        </div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-500 mb-2">Hình ảnh hiện tại</label>
        <div id="edit-product-images" class="grid grid-cols-4 gap-3"></div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-500 mb-2">Thêm ảnh mới</label>
        <input type="file" id="edit-product-new-images" name="images" multiple accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-primary file:text-white file:font-semibold file:text-xs hover:file:bg-primary-container file:cursor-pointer"/>
      </div>

      <div class="flex justify-end gap-3 pt-4">
        <button type="button" onclick="closeEditProductModal()" class="px-5 py-2.5 bg-gray-100 text-gray-600 rounded-lg font-semibold text-sm hover:bg-gray-200 transition-colors">Hủy</button>
        <button type="submit" class="px-5 py-2.5 bg-primary text-white rounded-lg font-semibold text-sm hover:bg-primary-container transition-colors">Lưu thay đổi</button>
      </div>
    </form>
  </div>
</div>

<div id="toast-container" class="toast-container"></div>
<script src="/js/app.js"></script>
<script src="/js/admin.js"></script>
<script>document.addEventListener('DOMContentLoaded', () => window.AdminApp && window.AdminApp.initProducts());</script>
<script>
(function() {
  var toggle = document.getElementById('sidebar-toggle');
  var sidebar = document.getElementById('admin-sidebar');
  var overlay = document.getElementById('sidebar-overlay');
  function openSidebar() {
    sidebar.style.transform = 'translateX(0)';
    overlay.style.display = 'block';
  }
  function closeSidebar() {
    sidebar.style.transform = 'translateX(-100%)';
    overlay.style.display = 'none';
  }
  if (toggle) toggle.addEventListener('click', openSidebar);
  if (overlay) overlay.addEventListener('click', closeSidebar);
  var navLinks = sidebar ? sidebar.querySelectorAll('a') : [];
  navLinks.forEach(function(link) {
    link.addEventListener('click', function() {
      if (window.innerWidth < 1024) closeSidebar();
    });
  });
})();
</script>
</body>
</html>
