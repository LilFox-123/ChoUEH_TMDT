<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chi tiết sản phẩm - Chợ UEH</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    rel="stylesheet" />
  <link href="/css/custom.css" rel="stylesheet" />
  <script>tailwind.config = { darkMode: "class", theme: { extend: { colors: { "primary": "#00464d", "primary-container": "#005f69", "primary-fixed": "#a7eefa", "secondary": "#35618c", "secondary-container": "#a2cdfe", "secondary-fixed": "#d0e4ff", "on-secondary-fixed": "#001d35", "tertiary": "#712600", "tertiary-fixed": "#ffdbce", "surface": "#f2fbfc", "surface-container-lowest": "#ffffff", "surface-container-low": "#ecf5f6", "surface-container": "#e7f0f0", "surface-container-high": "#e1eaeb", "on-surface": "#151d1e", "on-surface-variant": "#3f484a", "outline": "#6f797a", "outline-variant": "#bec8ca", "background": "#f2fbfc", "error": "#ba1a1a", "accent-orange": "#EC6D33" }, fontFamily: { "headline": ["Plus Jakarta Sans"], "body": ["Inter"] }, borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" } } } }</script>
</head>

<body class="bg-background text-on-surface antialiased">

  <%- include('partials/navbar') %>

    <main class="pt-24 pb-16 px-6 max-w-7xl mx-auto">
      <nav class="mb-8 flex items-center gap-2 text-sm text-on-surface-variant">
        <a class="hover:text-primary transition-colors" href="/">Trang chủ</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <a class="hover:text-primary transition-colors" href="/products">Sản phẩm</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="font-medium text-primary" id="breadcrumb-title">Đang tải...</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-7 space-y-4">
          <div class="bg-surface-container-lowest rounded-xl overflow-hidden aspect-[4/3] group relative">
            <img id="main-image" alt="Product"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="" />
          </div>
          <div id="thumbnails" class="grid grid-cols-5 gap-3"></div>

          <div id="quick-info-block"
            class="hidden bg-surface-container-lowest rounded-xl border border-outline-variant/15 p-5 space-y-3">
            <h3 class="text-sm font-bold text-on-surface-variant uppercase tracking-wider">Thông tin sản phẩm</h3>
            <div class="grid grid-cols-2 gap-3">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-base">visibility</span>
                <div>
                  <p class="text-xs text-on-surface-variant">Lượt xem</p>
                  <p id="info-views" class="text-sm font-bold text-on-surface">–</p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-base">schedule</span>
                <div>
                  <p class="text-xs text-on-surface-variant">Đăng lúc</p>
                  <p id="info-time" class="text-sm font-bold text-on-surface">–</p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-base">category</span>
                <div>
                  <p class="text-xs text-on-surface-variant">Danh mục</p>
                  <p id="info-category" class="text-sm font-bold text-on-surface">–</p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-base">location_on</span>
                <div>
                  <p class="text-xs text-on-surface-variant">Khu vực</p>
                  <p id="info-location" class="text-sm font-bold text-on-surface">–</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-[#fff8e1] border border-[#f4ddb0] rounded-xl p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="material-symbols-outlined text-[#c68a00] text-base">verified_user</span>
              <h3 class="text-sm font-bold text-[#c68a00]">Giao dịch an toàn</h3>
            </div>
            <ul class="space-y-2 text-xs text-[#7a5500]">
              <li class="flex items-start gap-2"><span
                  class="material-symbols-outlined text-xs mt-0.5">check_circle</span>Gặp mặt trực tiếp tại các điểm hẹn
                trong campus UEH</li>
              <li class="flex items-start gap-2"><span
                  class="material-symbols-outlined text-xs mt-0.5">check_circle</span>Kiểm tra kỹ sản phẩm trước khi
                thanh toán</li>
              <li class="flex items-start gap-2"><span
                  class="material-symbols-outlined text-xs mt-0.5">check_circle</span>Chỉ chuyển tiền sau khi đã nhận và
                kiểm tra hàng</li>
              <li class="flex items-start gap-2"><span
                  class="material-symbols-outlined text-xs mt-0.5">check_circle</span>Ưu tiên giao dịch trong giờ học,
                nơi đông người</li>
            </ul>
          </div>

          <%# Block: Chia sẻ sản phẩm %>
            <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/15 p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-primary text-base">share</span>
                <h3 class="text-sm font-bold text-on-surface-variant uppercase tracking-wider">Chia sẻ sản phẩm</h3>
              </div>
              <div class="flex items-center gap-2">
                <button id="share-copy-link"
                  class="flex-1 flex items-center justify-center gap-2 py-2 px-3 rounded-lg border border-outline-variant/30 text-xs font-semibold text-on-surface hover:bg-surface-container-low transition-colors">
                  <span class="material-symbols-outlined text-sm">link</span>
                  Sao chép link
                </button>
                <a id="share-facebook" href="#" target="_blank" rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 py-2 px-3 rounded-lg bg-[#1877f2] text-white text-xs font-semibold hover:bg-[#1464d8] transition-colors">
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                    <path
                      d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.269h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z" />
                  </svg>
                  Facebook
                </a>
                <a id="share-zalo" href="#" target="_blank" rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 py-2 px-3 rounded-lg bg-[#0068ff] text-white text-xs font-semibold hover:bg-[#0057d6] transition-colors">
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                    <path
                      d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.441 16.471c-.43.34-.96.529-1.51.529-.31 0-.62-.06-.91-.18l-1.97-.82c-.27.17-.56.31-.87.41l-.3.09c-1.04.3-2.13.24-3.13-.18-1-.42-1.82-1.17-2.33-2.13-.51-.96-.65-2.06-.4-3.11.25-1.05.87-1.97 1.75-2.6.88-.63 1.94-.93 3.01-.86 1.07.07 2.08.51 2.85 1.25.77.74 1.24 1.74 1.33 2.81l1.96.82c.55.23.97.69 1.14 1.26.17.57.07 1.18-.26 1.67l-.34.02zm-2.54-5.02c-.07-.74-.4-1.43-.93-1.94-.53-.51-1.23-.81-1.97-.86-.74-.05-1.47.16-2.07.59-.6.43-1.03 1.07-1.2 1.79-.17.72-.07 1.48.27 2.13.35.66.92 1.17 1.6 1.46.68.29 1.44.34 2.15.12l.2-.06c.22-.07.43-.16.63-.28l.29-.18.29.12 1.35.56-.36-1.45z" />
                  </svg>
                  Zalo
                </a>
              </div>
              <p id="share-copied-msg" class="hidden text-xs text-primary mt-2 text-center">✓ Đã sao chép link vào
                clipboard!</p>
            </div>

            <%# Block: Báo cáo bài đăng %>
              <div class="flex items-center justify-center pt-1 pb-2">
                <button id="report-btn"
                  class="flex items-center gap-1.5 text-xs text-on-surface-variant/60 hover:text-red-500 transition-colors group">
                  <span class="material-symbols-outlined text-sm group-hover:text-red-500">flag</span>
                  Báo cáo bài đăng này
                </button>
              </div>

              <%# Modal báo cáo %>
                <div id="report-modal"
                  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                  <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-sm mx-4">
                    <div class="flex items-center gap-2 mb-4">
                      <span class="material-symbols-outlined text-red-500">flag</span>
                      <h3 class="text-base font-bold text-on-surface">Báo cáo bài đăng</h3>
                    </div>
                    <p class="text-xs text-on-surface-variant mb-3">Chọn lý do báo cáo:</p>
                    <div class="space-y-2 mb-4">
                      <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="report-reason"
                          value="spam" class="accent-primary"> <span class="text-sm text-on-surface">Spam hoặc quảng
                          cáo</span></label>
                      <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="report-reason"
                          value="fake" class="accent-primary"> <span class="text-sm text-on-surface">Thông tin sai lệch
                          / lừa đảo</span></label>
                      <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="report-reason"
                          value="duplicate" class="accent-primary"> <span class="text-sm text-on-surface">Bài đăng trùng
                          lặp</span></label>
                      <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="report-reason"
                          value="inappropriate" class="accent-primary"> <span class="text-sm text-on-surface">Nội dung
                          không phù hợp</span></label>
                      <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="report-reason"
                          value="other" class="accent-primary"> <span class="text-sm text-on-surface">Lý do
                          khác</span></label>
                    </div>
                    <div class="flex gap-2">
                      <button id="report-cancel"
                        class="flex-1 py-2 rounded-lg border border-outline-variant/30 text-sm text-on-surface-variant hover:bg-surface-container-low transition-colors">Huỷ</button>
                      <button id="report-submit"
                        class="flex-1 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold hover:bg-red-600 transition-colors">Gửi
                        báo cáo</button>
                    </div>
                  </div>
                </div>
        </div>

        <div class="lg:col-span-5 space-y-6">
          <div id="detail-shell"
            class="bg-surface-container-lowest p-8 rounded-xl shadow-sm border border-outline-variant/15">
            <div class="mb-4 flex items-center gap-3 flex-wrap">
              <span id="product-condition"
                class="bg-secondary-fixed text-on-secondary-fixed px-3 py-1 rounded-full text-xs font-semibold"></span>
              <span id="listing-type-badge"
                class="px-3 py-1 rounded-full text-xs font-semibold bg-primary-fixed text-primary">Đang bán</span>
            </div>

            <h1 id="product-title" class="text-3xl font-extrabold text-on-surface leading-tight mb-2"></h1>
            <p id="product-meta" class="text-on-surface-variant text-sm mb-3"></p>
            <p id="product-price-caption"
              class="text-xs font-semibold uppercase tracking-[0.18em] text-on-surface-variant mb-2">Giá bán</p>
            <div id="product-price" class="text-4xl font-black text-primary mb-6 tracking-tight"></div>

            <div id="wanted-context-card" class="hidden mb-4 rounded-2xl border border-[#f1dca9] bg-[#fff9ea] p-4">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-white/80 text-[#b88400] flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined">campaign</span>
                </div>
                <div class="space-y-2 flex-1">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#9a6b00]">Bài đăng đang cần</p>
                    <h2 class="text-base font-bold text-on-surface">Sinh viên đang tìm món đồ phù hợp</h2>
                  </div>
                  <div id="wanted-context-meta" class="flex flex-wrap gap-2 text-xs"></div>
                </div>
              </div>
            </div>

            <div id="ueh-context-badge"
              class="hidden mb-4 rounded-2xl border border-primary/15 bg-primary-fixed/20 p-4">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-white/70 text-primary flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined">school</span>
                </div>
                <div class="space-y-2 flex-1">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">Ngữ cảnh UEH</p>
                    <h2 id="ueh-context-title" class="text-base font-bold text-on-surface"></h2>
                  </div>
                  <div id="ueh-context-meta" class="flex flex-wrap gap-2 text-xs"></div>
                </div>
              </div>
            </div>

            <div id="meeting-context-card"
              class="hidden mb-8 rounded-2xl border border-secondary/15 bg-secondary-fixed/30 p-4">
              <div class="flex items-start gap-3">
                <div
                  class="w-10 h-10 rounded-xl bg-white/70 text-secondary flex items-center justify-center shrink-0 text-lg">
                  📍</div>
                <div class="space-y-3 flex-1">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">Điểm hẹn UEH</p>
                    <h2 class="text-base font-bold text-on-surface">Địa điểm và khung giờ giao nhận</h2>
                  </div>
                  <div id="meeting-points-badges" class="flex flex-wrap gap-2 text-xs"></div>
                  <div id="preferred-time-slots-badges" class="flex flex-wrap gap-2 text-xs"></div>
                </div>
              </div>
            </div>

            <div id="seller-card"
              class="flex items-center gap-4 p-4 bg-surface-container-low rounded-xl mb-8 cursor-pointer hover:bg-surface-container transition-colors">
            </div>

            <!-- Rating Section - will be shown/hidden by JS based on conditions -->
            <div id="rating-section"
              class="hidden mb-8 bg-surface-container-lowest rounded-xl border border-outline-variant/15 p-5">
              <h3 class="text-base font-bold text-on-surface mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-yellow-500">star</span>
                Đánh giá người bán
              </h3>
              <div id="rating-form">
                <div id="rating-stars" class="flex items-center gap-1 mb-4">
                  <button type="button" data-star="1"
                    class="star-btn text-3xl text-gray-300 hover:text-yellow-400 transition-colors">
                    <span class="material-symbols-outlined" style="font-size: inherit;">star</span>
                  </button>
                  <button type="button" data-star="2"
                    class="star-btn text-3xl text-gray-300 hover:text-yellow-400 transition-colors">
                    <span class="material-symbols-outlined" style="font-size: inherit;">star</span>
                  </button>
                  <button type="button" data-star="3"
                    class="star-btn text-3xl text-gray-300 hover:text-yellow-400 transition-colors">
                    <span class="material-symbols-outlined" style="font-size: inherit;">star</span>
                  </button>
                  <button type="button" data-star="4"
                    class="star-btn text-3xl text-gray-300 hover:text-yellow-400 transition-colors">
                    <span class="material-symbols-outlined" style="font-size: inherit;">star</span>
                  </button>
                  <button type="button" data-star="5"
                    class="star-btn text-3xl text-gray-300 hover:text-yellow-400 transition-colors">
                    <span class="material-symbols-outlined" style="font-size: inherit;">star</span>
                  </button>
                </div>
                <textarea id="rating-comment"
                  class="w-full border border-outline-variant/30 rounded-lg p-3 text-sm resize-none focus:ring-2 focus:ring-primary focus:border-transparent"
                  rows="3" maxlength="500" placeholder="Chia sẻ trải nghiệm của bạn (không bắt buộc)..."></textarea>
                <button id="submit-rating" type="button"
                  class="mt-3 w-full bg-primary text-white py-3 rounded-lg font-bold hover:brightness-110 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                  disabled>
                  Gửi đánh giá
                </button>
              </div>
              <div id="rating-success" class="hidden text-center py-4">
                <span class="material-symbols-outlined text-4xl text-green-500 mb-2">check_circle</span>
                <p class="text-green-700 font-semibold">✅ Cảm ơn bạn đã đánh giá!</p>
              </div>
            </div>

            <div class="flex flex-col gap-3">
              <button id="btn-message"
                class="w-full bg-[#EC6D33] text-white py-4 rounded-lg font-bold text-lg shadow-md hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">chat</span>
                <span id="btn-message-label">Nhắn tin</span>
              </button>
            </div>
          </div>

          <div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm border border-outline-variant/15">
            <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">description</span> Mô tả chi tiết
            </h2>
            <div id="product-description" class="text-on-surface-variant leading-relaxed whitespace-pre-line"></div>
          </div>
        </div>
      </div>

      <section class="mt-16">
        <h2 class="text-2xl font-black text-on-surface tracking-tight mb-8">Bài đăng tương tự</h2>
        <div id="related-products" class="grid grid-cols-2 md:grid-cols-4 gap-6"></div>
      </section>

      <div id="lightbox" class="hidden fixed inset-0 z-[9999] flex items-center justify-center"
        style="background:rgba(0,0,0,0.9);">
        <button id="lightbox-close"
          class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/25 transition-all z-10">
          <span class="material-symbols-outlined">close</span>
        </button>
        <button id="lightbox-prev"
          class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/25 transition-all z-10">
          <span class="material-symbols-outlined">chevron_left</span>
        </button>
        <button id="lightbox-next"
          class="absolute right-14 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/25 transition-all z-10">
          <span class="material-symbols-outlined">chevron_right</span>
        </button>
        <img id="lightbox-img" class="max-w-[90vw] max-h-[90vh] object-contain rounded-lg shadow-2xl" src="" alt="" />
        <div id="lightbox-counter"
          class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-sm font-medium"></div>
      </div>
    </main>

    <%- include('partials/footer') %>

      <div id="toast-container" class="toast-container"></div>
      <script src="/js/app.js"></script>
      <script src="/js/product-detail.js"></script>
      <script>
        const PRODUCT_ID = '<%= productId %>';
      </script>
</body>

</html>