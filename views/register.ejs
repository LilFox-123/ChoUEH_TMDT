<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Đăng Ký - Chợ UEH</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/css/custom.css" rel="stylesheet"/>
  <script>tailwind.config={darkMode:"class",theme:{extend:{colors:{"primary":"#00464d","primary-container":"#005f69","primary-fixed":"#a7eefa","tertiary":"#712600","tertiary-fixed":"#ffdbce","surface":"#f2fbfc","surface-container-lowest":"#ffffff","surface-container":"#e7f0f0","surface-container-high":"#e1eaeb","on-surface":"#151d1e","on-surface-variant":"#3f484a","outline":"#6f797a","outline-variant":"#bec8ca","background":"#f2fbfc","secondary-fixed":"#d0e4ff","on-secondary-fixed":"#001d35"},fontFamily:{"headline":["Plus Jakarta Sans"],"body":["Inter"]},borderRadius:{"DEFAULT":"0.25rem","lg":"0.5rem","xl":"0.75rem","full":"9999px"}}}}</script>
  <style>.bg-signature-gradient{background:linear-gradient(135deg,#00464d 0%,#005f69 100%);}</style>
</head>
<body class="bg-background font-body text-on-surface overflow-x-hidden">
<main class="min-h-screen flex flex-col md:flex-row">
  <!-- LEFT PANEL -->
  <section class="md:w-[40%] bg-signature-gradient p-8 md:p-12 flex flex-col justify-between relative overflow-hidden">
    <div class="absolute -top-24 -left-24 w-64 h-64 bg-primary-container/20 rounded-full blur-3xl"></div>
    <div class="relative z-10">
      <a href="/" class="cho-ueh-logo logo-white mb-12 inline-flex">
        <div class="logo-emblem"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 3L2 7.5L11 12L20 7.5L11 3Z" fill="white" opacity="0.95"/><path d="M5 9.5V14.5C5 14.5 7.5 17 11 17C14.5 17 17 14.5 17 14.5V9.5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/><line x1="18.5" y1="8" x2="18.5" y2="13" stroke="white" stroke-width="1.8" stroke-linecap="round"/><circle cx="18.5" cy="7" r="1.5" fill="white"/></svg></div>
        <div class="logo-wordmark"><span class="logo-cho">Chợ</span><span class="logo-ueh-text">UEH<span class="accent-dot">.</span></span></div>
      </a>
      <h2 class="font-headline font-bold text-3xl lg:text-4xl text-white mb-8 leading-tight">Nền tảng mua bán đồ cũ dành riêng cho sinh viên UEH</h2>
      <div class="space-y-6">
        <div class="flex items-center gap-4"><div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center text-primary-fixed"><span class="material-symbols-outlined">verified_user</span></div><p class="text-white font-medium">Chỉ dành cho sinh viên UEH</p></div>
        <div class="flex items-center gap-4"><div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center text-primary-fixed"><span class="material-symbols-outlined">security</span></div><p class="text-white font-medium">Giao dịch an toàn, minh bạch</p></div>
        <div class="flex items-center gap-4"><div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center text-primary-fixed"><span class="material-symbols-outlined">payments</span></div><p class="text-white font-medium">Tiết kiệm chi phí học tập</p></div>
      </div>
    </div>
    <div class="relative z-10 pt-8 text-primary-fixed/60 text-xs font-medium border-t border-white/10 mt-8">© 2024 University of Economics Ho Chi Minh City</div>
  </section>

  <!-- RIGHT PANEL -->
  <section class="md:w-[60%] bg-surface-container-lowest p-8 md:p-16 lg:px-24 flex flex-col justify-center">
    <div class="max-w-2xl mx-auto w-full">
      <div class="mb-10 text-center md:text-left">
        <h2 class="font-headline font-extrabold text-4xl text-primary mb-3">Tạo tài khoản mới</h2>
        <p class="text-on-surface-variant">Đã có tài khoản? <a class="text-tertiary font-semibold hover:underline" href="/login">Đăng nhập ngay</a></p>
      </div>
      <form id="register-form" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant px-1">Họ và tên *</label>
            <input id="reg-name" class="w-full px-4 py-3 rounded-xl bg-surface-container border-none focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none placeholder:text-outline/50" placeholder="Nguyễn Văn A" type="text" required/>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant px-1">Email *</label>
            <input id="reg-email" class="w-full px-4 py-3 rounded-xl bg-surface-container border-none focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none placeholder:text-outline/50" placeholder="email@st.ueh.edu.vn" type="email" required/>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant px-1">MSSV *</label>
            <input id="reg-studentId" class="w-full px-4 py-3 rounded-xl bg-surface-container border-none focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none placeholder:text-outline/50" placeholder="3121102xxxx" type="text" required/>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant px-1">Số điện thoại</label>
            <input id="reg-phone" class="w-full px-4 py-3 rounded-xl bg-surface-container border-none focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none placeholder:text-outline/50" placeholder="090 123 4567" type="tel"/>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant px-1">Khoa</label>
            <select id="reg-department" class="w-full px-4 py-3 rounded-xl bg-surface-container border-none focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none">
              <option>Khoa Kinh tế</option><option>Khoa Quản trị</option><option>Khoa Tài chính</option><option>Khoa Kế toán</option><option>Khoa Công nghệ thông tin kinh doanh</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant px-1">Khóa</label>
            <select id="reg-year" class="w-full px-4 py-3 rounded-xl bg-surface-container border-none focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none">
              <option>Khóa 47</option><option>Khóa 48</option><option>Khóa 49</option><option>Khóa 50</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant px-1">Mật khẩu *</label>
            <input id="reg-password" class="w-full px-4 py-3 rounded-xl bg-surface-container border-none focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none placeholder:text-outline/50" placeholder="••••••••" type="password" required/>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant px-1">Xác nhận mật khẩu *</label>
            <input id="reg-confirm" class="w-full px-4 py-3 rounded-xl bg-surface-container border-none focus:ring-2 focus:ring-primary focus:bg-white transition-all outline-none placeholder:text-outline/50" placeholder="••••••••" type="password" required/>
          </div>
        </div>
        <div id="register-error" class="hidden p-3 bg-red-50 text-red-700 rounded-lg text-sm font-medium"></div>
        <button class="w-full py-4 bg-tertiary text-white rounded-xl font-bold text-lg shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-[0.98] transition-all flex items-center justify-center gap-2" type="submit" id="register-btn">
          Đăng Ký Ngay <span class="material-symbols-outlined">arrow_forward</span>
        </button>
      </form>
    </div>
  </section>
</main>

<div id="toast-container" class="toast-container"></div>
<script src="/js/app.js"></script>
<script src="/js/auth.js"></script>
</body>
</html>
